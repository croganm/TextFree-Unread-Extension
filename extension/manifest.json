{
  "manifest_version": 3,
  "name": "TextFree Mark Unread",
  "version": "1.1.0",
  "description": "TextFree Web: local mark-unread reminders, copy phone number, and copy conversation with timestamps.",
  "permissions": ["scripting", "storage", "clipboardWrite"],
  "host_permissions": ["https://messages.textfree.us/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://messages.textfree.us/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
